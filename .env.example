# TrendPulse v6 — Environment Configuration
# Copy this to .env and fill in your values

# ── Security (REQUIRED — auto-generated on first run if empty) ─────────────
# The app will auto-generate a SECRET_KEY on first startup if this is empty.
# For production, set it explicitly.
SECRET_KEY=

# ── CORS (for production, set your domain) ────────────────────────────────
# Comma-separated list of allowed origins. Use "*" for development.
CORS_ORIGINS=*

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_PATH=data/saas.db

# ── LLM API Keys (can also be set per-user in Account → API Keys) ─────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
AIML_API_KEY=

# ── Output directory ──────────────────────────────────────────────────────
OUTPUT_DIR=outputs
